HUGGINGFACE_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
SENTRY_DSN=
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/loopforge
POSTGRES_PASSWORD=changeme_in_prod
REDIS_URL=redis://localhost:6379
CHROMA_PERSIST_DIR=./chroma_db
CONVERGENCE_THRESHOLD=7.5
MAX_ITERATIONS_DEFAULT=5
TOKEN_BUDGET_PER_TASK=8000
ALLOWED_ORIGINS=http://localhost:8501
ENVIRONMENT=development

# ── Loop Studio ────────────────────────────────────────────────────────────────

# Fernet key for encrypting notification configs
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NOTIFICATION_ENCRYPTION_KEY=

# Redis URL for celery-redbeat Beat scheduler (same as REDIS_URL)
REDBEAT_REDIS_URL=redis://localhost:6379

# SendGrid — email notifications
SENDGRID_API_KEY=

# Public base URL — used in notification message links
# e.g. https://loopforge.onrender.com  or  http://localhost:8010
BASE_URL=http://localhost:8010

# Concurrency limits per role (simultaneous running loops)
LOOP_CONCURRENCY_FREE=1
LOOP_CONCURRENCY_PRO=5

# Max loops a free user can create (quota enforced at CREATE time)
LOOP_QUOTA_FREE=2

# MCP fetch timeout in seconds
MCP_TIMEOUT_SECONDS=10
